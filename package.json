{
  "name": "hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node server/railway.mjs",
    "start:replit": "node server/replit.mjs",
    "dev": "vite --port 5173 --host 0.0.0.0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && node scripts/check-imports.mjs",
    "lint:imports": "node scripts/check-imports.mjs",
    "build": "node scripts/check-imports.mjs && vite build",
    "build:analyze": "cross-env ANALYZE=1 node scripts/check-imports.mjs && cross-env ANALYZE=1 vite build",
    "preview": "vite preview",
    "test": "node scripts/vitest.mjs run",
    "test:watch": "node scripts/vitest.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/node": "^8.55.1",
    "@sentry/react": "^8.55.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "better-auth": "^1.6.4",
    "body-highlighter": "^3.0.2",
    "clsx": "^2.1.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.14.1",
    "react-virtuoso": "^4.18.5",
    "tailwind-merge": "^2.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.25",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.0"
  },
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
