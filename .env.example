# ── Бекенд (Railway / локальний сервер) ──────────────────────────────────────

# Ключ Anthropic Claude API (обов'язково)
ANTHROPIC_API_KEY=

# Токен Nutritionix API (опційно, для nutrition-ендпоінтів)
NUTRITION_API_TOKEN=

# Додаткові CORS origins через кому (опційно)
# Приклад: https://my-preview.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=

# ── Фронт (Vite) ──────────────────────────────────────────────────────────────

# Базовий URL бекенду без завершального `/`
# Порожньо → відносні шляхи /api/* (локально Vite проксує на VITE_API_PROXY_TARGET)
# Прод на Vercel + API на Railway: https://your-service.up.railway.app
VITE_API_BASE_URL=

# Лише для `vite dev`: куди проксувати /api (за замовчуванням локальний Express з package.json start)
# VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# Токен Nutritionix для мобільного / прямих запитів з фронту (опційно)
VITE_NUTRITION_API_TOKEN=
