# ─────────────────────────────────────────────────────────────
# Hub — змінні середовища
# Скопіюйте цей файл у .env та заповніть значення.
# Ніколи не комітьте реальний .env у git.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
# Повний connection string для pg.Pool
DATABASE_URL=postgresql://user:password@localhost:5432/hub

# ── Better Auth ───────────────────────────────────────────────
# Базова URL (автоматично визначається, якщо є REPLIT_DEV_DOMAIN)
BETTER_AUTH_URL=http://localhost:3000

# Секрет для підпису сесійних кукі (мін. 32 символи)
BETTER_AUTH_SECRET=change_me_to_a_long_random_string_32chars

# ── Anthropic Claude API ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Nutrition API Token ───────────────────────────────────────
# Використовується для захисту nutrition endpoints (опціонально)
NUTRITION_API_TOKEN=

# ── USDA FoodData Central (штрихкоди) ────────────────────────
# Безкоштовний ключ: https://api.data.gov/signup
# Без ключа використовується DEMO_KEY (40 req/hr shared limit).
USDA_FDC_API_KEY=

# ── Web Push / VAPID ─────────────────────────────────────────
# Згенеруйте: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Внутрішній секрет для /api/push/send (щоб захистити від довільних запитів)
API_SECRET=change_me_to_a_random_string

# ── CORS ──────────────────────────────────────────────────────
# Через кому: додаткові origins, яким дозволено звертатись до API
ALLOWED_ORIGINS=http://localhost:5173

# ── Порт Express ─────────────────────────────────────────────
PORT=3000

# ── Vite (frontend) ───────────────────────────────────────────
# Базова URL API для продакшн (якщо фронтенд і API на різних доменах)
VITE_API_BASE_URL=https://your-api.railway.app

# Токен для nutrition endpoints (має збігатись з NUTRITION_API_TOKEN)
VITE_NUTRITION_API_TOKEN=

# Proxy ціль в dev режимі (вказує на локальний Express)
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# ── Replit (опціонально, авто-визначається) ───────────────────
# REPLIT_DEV_DOMAIN=your-repl.repl.co
# REPLIT_DOMAINS=your-repl.repl.co
