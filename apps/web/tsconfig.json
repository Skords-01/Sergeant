{
  "extends": "@sergeant/config/tsconfig.react.json",
  "compilerOptions": {
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "types": ["vite/client"],
    "paths": {
      "@sergeant/shared": ["../../packages/shared/src/index.ts"],
      "@sergeant/shared/*": ["../../packages/shared/src/*"],
      "@sergeant/api-client": ["../../packages/api-client/src/index.ts"],
      "@sergeant/api-client/react": [
        "../../packages/api-client/src/react/index.ts"
      ],
      "@sergeant/api-client/*": ["../../packages/api-client/src/*"],
      "@sergeant/finyk-domain": ["../../packages/finyk-domain/src/index.ts"],
      "@sergeant/finyk-domain/*": ["../../packages/finyk-domain/src/*"],
      "@sergeant/fizruk-domain": ["../../packages/fizruk-domain/src/index.ts"],
      "@sergeant/fizruk-domain/*": ["../../packages/fizruk-domain/src/*"],
      "@sergeant/insights": ["../../packages/insights/src/index.ts"],
      "@sergeant/insights/*": ["../../packages/insights/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@finyk/*": ["./src/modules/finyk/*"],
      "@fizruk/*": ["./src/modules/fizruk/*"],
      "@routine/*": ["./src/modules/routine/*"],
      "@nutrition/*": ["./src/modules/nutrition/*"]
    }
  },
  "include": ["src/**/*", "vite.config.js", "vitest.config.js"],
  "exclude": ["node_modules", "dist", "src/sw.ts"]
}
