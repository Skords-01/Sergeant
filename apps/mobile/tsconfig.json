{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./app/*"],
      "@sergeant/shared": ["../../packages/shared/src/index.ts"],
      "@sergeant/shared/*": ["../../packages/shared/src/*"],
      "@sergeant/api-client": ["../../packages/api-client/src/index.ts"],
      "@sergeant/api-client/*": ["../../packages/api-client/src/*"],
      "@sergeant/fizruk-domain": ["../../packages/fizruk-domain/src/index.ts"],
      "@sergeant/fizruk-domain/*": ["../../packages/fizruk-domain/src/*"],
      "@sergeant/finyk-domain": ["../../packages/finyk-domain/src/index.ts"],
      "@sergeant/finyk-domain/*": ["../../packages/finyk-domain/src/*"],
      "@sergeant/design-tokens": ["../../packages/design-tokens/index.d.ts"],
      "@sergeant/design-tokens/*": ["../../packages/design-tokens/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "app.config.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
