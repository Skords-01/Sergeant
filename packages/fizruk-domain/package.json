{
  "name": "@sergeant/fizruk-domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts",
    "./data": "./src/data/index.ts",
    "./data/*": "./src/data/*",
    "./domain": "./src/domain/index.ts",
    "./domain/*": "./src/domain/*.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sergeant/shared": "workspace:*"
  },
  "devDependencies": {
    "@sergeant/config": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  }
}
